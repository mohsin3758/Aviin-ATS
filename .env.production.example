# Production environment variables
# Copy to .env and fill in secrets before deploying
# NEVER commit this file to git

# Database
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
APP_DB_PASSWORD=CHANGE_ME_APP_PASSWORD

# Auth
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# Frontend
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN/api

# WAHA (WhatsApp)
WAHA_API_KEY=CHANGE_ME

# n8n
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_STRING
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# AI (all local — no external API keys needed)
OLLAMA_MODEL=qwen2.5:1.5b-instruct-q4_K_M
EMBED_MODEL=bge-small-en-v1.5

# Ports (internal — nginx handles external)
DB_PORT=5432
BACKEND_PORT=8080
FRONTEND_PORT=3001
EMBED_PORT=8081
OLLAMA_PORT=11434
N8N_PORT=5678
WAHA_PORT=3000
