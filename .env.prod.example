# FinStack Staffing OS — Production Environment Template
# Copy to .env.prod and fill in all values before running deploy-prod.sh
#
# DOMAIN: Confirm with team before P14 — do NOT use finstack.aviinjobs.com
#   (that subdomain may already be in use by the FinStack HR/Payroll product)

# ─── Domain (REQUIRED — fill in before deploy) ───────────────────────────────
DOMAIN=CHANGEME.yourdomain.com

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=ats
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_STRONG_RANDOM_64_CHARS

APP_DB_USER=app_user
APP_DB_PASSWORD=CHANGEME_APP_USER_PASSWORD

DB_PORT=5432

# ─── Service ports (internal — nginx proxies externally) ─────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3001
EMBED_PORT=8081
OLLAMA_PORT=11434
N8N_PORT=5678
WAHA_PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGEME_STRONG_RANDOM_64_CHARS
JWT_ALGORITHM=HS256

# ─── AI services ─────────────────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:1.5b-instruct-q4_K_M

# ─── ERP Encryption (HARD RULE #11) ──────────────────────────────────────────
# MUST be a strong random key — changing this after data is stored breaks decryption
ERP_ENCRYPT_KEY=CHANGEME_STRONG_RANDOM_32_CHARS

# ─── WhatsApp (WAHA) ─────────────────────────────────────────────────────────
# Auto-discovered from WAHA logs on first run; set here for reproducibility
WAHA_API_KEY=CHANGEME_FROM_WAHA_LOGS

# ─── n8n ─────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGEME_STRONG_PASSWORD
N8N_ENCRYPTION_KEY=CHANGEME_STRONG_RANDOM_32_CHARS

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://CHANGEME.yourdomain.com

# ─── QA / Testing ─────────────────────────────────────────────────────────────
QA_EMAIL=admin@example.com
QA_PASSWORD=CHANGEME_ADMIN_PASSWORD
