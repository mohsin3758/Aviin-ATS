# FinStack Staffing OS (AIrecruit) — environment template
# Copy to `.env` (gitignored) and adjust secrets for your environment.

# --- Postgres superuser (docker init scripts only — HARD RULE #9 says
# app code never connects as this role, only sql/*.sql init scripts do) ---
POSTGRES_DB=ats
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_superuser_pw

# --- App DB role (app code ALWAYS uses this — HARD RULE #2/#9) ---
APP_DB_USER=app_user
APP_DB_PASSWORD=apppw

# --- Ports (host side) ---
DB_PORT=5432
BACKEND_PORT=8080
FRONTEND_PORT=3001
EMBED_PORT=8081
OLLAMA_PORT=11434
N8N_PORT=5678
WAHA_PORT=3000

# --- Backend / Auth ---
JWT_SECRET=changeme_jwt_secret
JWT_ALGORITHM=HS256

# --- Ollama (Qwen2.5-1.5B — HARD RULE #1/#4) ---
OLLAMA_MODEL=qwen2.5:1.5b-instruct-q4_K_M

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_pw
N8N_ENCRYPTION_KEY=changeme_n8n_encryption_key

# --- QA (Playwright) ---
QA_EMAIL=admin@example.com
QA_PASSWORD=changeme
