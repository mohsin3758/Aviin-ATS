            "index": 0
          }
        ]
      ]
    },
    "Get open reqs needing posting": {
      "main": [
        [
          {
            "node": "Build queue-insert SQL",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build queue-insert SQL": {
      "main": [
        [
          {
            "node": "Queue job-board postings",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
